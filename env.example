# Connect to Supabase via connection pooling with Supavisor.
DATABASE_URL="postgres://postgres.[YOUR_DATABASE]:[YOUR_PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations.
DIRECT_URL="postgres://postgres.[YOUR_DATABASE]:[YOUR_PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Better Auth
BETTER_AUTH_SECRET="secret_key"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Phase 7: longform-to-shorts
# The longform-download worker requires these binaries in the runtime image:
#   - yt-dlp  (installed via `pip3 install yt-dlp` in the Railway Dockerfile)
#   - ffmpeg  (needed for clipping + bundles ffprobe used for file-mode probes)
# See Dockerfile for install instructions.

# Supabase Storage (Phase 7 retry 2, Codex CRITICAL-4)
# Better Auth sessions are not Supabase Auth JWTs, so the anon client's
# `auth.uid()` is NULL and RLS denies every storage op from the server.
# Worker handlers and API routes that touch the `longform-sources`
# bucket MUST use the service-role key, which bypasses RLS. The caller
# is responsible for enforcing `session.user.id` ownership via Drizzle
# before invoking any helper in `src/lib/media/longform-storage.ts`.
#
# REQUIRED for the Railway worker and for the web /api/longform routes.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
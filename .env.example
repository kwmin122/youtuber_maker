# Auth (better-auth)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database (Supabase PostgreSQL)
DATABASE_URL=

# Encryption
MASTER_ENCRYPTION_KEY=

# Queue (BullMQ)
REDIS_URL=

# Supabase (Realtime only - NOT auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-data-api-v3-key

# Admin
ADMIN_EMAIL=

# ---- Phase 9: Trend Intelligence ----
# Secret for Vercel Cron route authentication (min 16 chars). Required in production.
CRON_SECRET=your-cron-secret-min-16-chars
# Set to "true" to enable Google Trends enrichment (non-fatal, off by default).
GOOGLE_TRENDS_ENABLED=false

# ---- Phase 8: AI Avatar & Lipsync ----
# Admin BYOK keys used by scripts/seed-avatar-library.ts (Plan 08-02).
# Runtime user operations use per-user keys in the api_keys table.
HEYGEN_API_KEY=
D_ID_API_KEY=
